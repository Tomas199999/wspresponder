{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/generar", "dest": "/api/index.js" },
    { "src": "/usuario", "dest": "/api/index.js" },
    { "src": "/cambiar-plan", "dest": "/api/index.js" },
    { "src": "/suscribir", "dest": "/api/index.js" },
    { "src": "/verificar-pago", "dest": "/api/index.js" },
    { "src": "/webhook/mp", "dest": "/api/index.js" },
    { "src": "/historial/(.*)", "dest": "/api/index.js" },
    { "src": "/historial", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
